<!--                android:id="@+id/login_withotp"-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="?actionBarSize"-->
<!--                android:layout_marginTop="@dimen/spacing_normal"-->
<!--                android:text="Login With otp"-->
<!--                android:textColor="@android:color/white"-->
<!--                android:textSize="@dimen/size_15"-->
<!--                app:cornerRadius="@dimen/spacing_medium" />-->

            <RelativeLayout
                android:id="@+id/signup_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_20dp"
                android:gravity="center">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/signup_bt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:gravity="center"

                    android:padding="3dp"
                    android:text="@string/label_sign_up"
                    android:textColor="@color/black"
                    android:textSize="16sp" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/create_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:layout_toRightOf="@+id/signup_bt"
                    android:gravity="end"
                    android:padding="3dp"
                    android:text="@string/create_lable"
                    android:textColor="@color/cb_dark_blue_button"
                    android:textSize="16sp" />
            </RelativeLayout>


            <com.google.android.material.button.MaterialButton
                android:id="@+id/skip_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="@dimen/spacing_normal"
                android:text="@string/label_skip"


                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="@dimen/size_16"
                app:cornerRadius="@dimen/spacing_medium" />

        </androidx.appcompat.widget.LinearLayoutCompat>

    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_gravity="center_vertical|center_horizontal"
        android:id="@+id/pbUserLogin"/>
</androidx.coordinatorlayout.widget.CoordinatorLayout>