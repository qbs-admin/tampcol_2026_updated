<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/spacing_normal"
    android:paddingEnd="@dimen/spacing_normal">

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvCustomerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="abc"
        android:textColor="@color/textHeader"
        android:textSize="@dimen/size_16" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvCustomerEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tvCustomerName"
        android:fontFamily="@font/sfproregular"
        android:paddingTop="@dimen/margin_4"
        android:paddingBottom="@dimen/margin_4"
        android:text=""
        android:textColor="@color/textTitle"
        android:textSize="@dimen/size_16" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvCustomerPhone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tvCustomerEmail"
        android:fontFamily="@font/sfproregular"

        android:paddingBottom="@dimen/margin_4"
        android:text=""
        android:textColor="@color/textTitle"
        android:textSize="@dimen/size_16" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvCustomerrewardpts"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tvCustomerEmail"
        android:fontFamily="@font/sfproregular"
        android:visibility="gone"
        android:paddingBottom="@dimen/margin_4"
        android:text=""
        android:textColor="@color/textTitle"
        android:textSize="@dimen/size_16" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tvCustomerPhone"
        android:layout_marginTop="@dimen/spacing_small"
        android:orientation="horizontal"
        android:paddingTop="@dimen/margin_2"
        android:paddingBottom="@dimen/margin_2"
        android:visibility="gone"
        android:weightSum="1">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="@dimen/spacing_80"
            android:layout_weight="0.2"
            android:gravity="center|start"
            android:orientation="vertical">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvCustomerEarnedPoints"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:text="0"
                android:textColor="@color/textHeader"
                android:textSize="@dimen/size_18" />

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/sfproregular"
                android:text="@string/earned_points"
                android:textColor="@color/textHint"
                android:textSize="@dimen/size_18" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="@dimen/spacing_60"
            android:layout_gravity="center"
            android:background="@color/viewColor1" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="@dimen/spacing_80"
            android:layout_marginStart="@dimen/spacing_normal"
            android:layout_weight="0.2"
            android:gravity="center|start"
            android:orientation="vertical">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvCustomerSpendPoints"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:text="0"
                android:textColor="@color/textHeader"
                android:textSize="@dimen/size_18" />

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/sfproregular"
                android:text="@string/spend_points"
                android:textColor="@color/textHint"
                android:textSize="@dimen/size_18" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="@dimen/spacing_60"
            android:layout_gravity="center"

            android:background="@color/viewColor1" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="@dimen/spacing_80"
            android:layout_marginStart="@dimen/spacing_normal"
            android:layout_weight="0.25"
            android:gravity="center|start"
            android:orientation="vertical">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvCustomerBalancePoints"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:text="0"
                android:textColor="@color/textHeader"
                android:textSize="@dimen/size_18" />

            <androidx.appcompat.widget.AppCompatTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/sfproregular"
                android:text="@string/balance_points"
                android:textColor="@color/textHint"
                android:textSize="@dimen/size_18" />
        </LinearLayout>


    </LinearLayout>

</RelativeLayout>