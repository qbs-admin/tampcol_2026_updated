<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_height="wrap_content">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/spacing_normal"
        android:paddingTop="@dimen/margin_4"
        android:paddingEnd="@dimen/spacing_normal"
        android:paddingBottom="@dimen/margin_4">


        <androidx.cardview.widget.CardView
            android:id="@+id/cvProductImage"
            android:layout_width="@dimen/spacing_100"
            android:layout_height="@dimen/spacing_100"
            android:layout_alignParentStart="true"
            app:cardCornerRadius="@dimen/spacing_small"
            app:cardElevation="@dimen/margin_4"
            app:cardPreventCornerOverlap="true"
            app:cardUseCompatPadding="true">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">


                <ProgressBar
                    android:layout_width="@dimen/spacing_large"
                    android:layout_height="@dimen/spacing_large"
                    android:layout_centerInParent="true"
                    android:id="@+id/pbProductItem"/>


                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivProductImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="true"
                    android:scaleType="centerCrop" />
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/pr_ofer_img"
                    android:layout_width="@dimen/spacing_30"
                    android:scaleType="fitXY"
                    android:layout_weight="1"
                    android:src="@drawable/ic_offer"
                    android:layout_height="@dimen/spacing_30"/>

                <androidx.appcompat.widget.AppCompatTextView
                    android:layout_width="30dp"
                    android:id="@+id/pr_ofer_txt"
                    android:layout_height="@dimen/spacing_30"
                    android:gravity="center"
                    android:text=""
                    android:textStyle="bold"
                    android:textSize="@dimen/size_10"
                    android:textColor="@color/white" />


                <!-- <LinearLayout
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     android:layout_centerInParent="true">

                     <com.like.LikeButton
                         android:id="@+id/lkWishList"
                         android:layout_width="wrap_content"
                         android:layout_height="wrap_content"
                         android:visibility="visible"
                         app:like_drawable="@drawable/ic_favourite_filled"
                         app:unlike_drawable="@drawable/ic_favourite_unfilled" />
                 </LinearLayout>-->

            </RelativeLayout>


        </androidx.cardview.widget.CardView>

        <androidx.appcompat.widget.AppCompatSpinner
            android:id="@+id/tv_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/linearPrice"
            android:layout_marginStart="@dimen/margin_5"
            android:layout_marginEnd="@dimen/margin_5"
            android:layout_toStartOf="@+id/tv_linear"
            android:layout_toEndOf="@+id/cvProductImage" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvCategoryName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_14"
            android:layout_toEndOf="@+id/cvProductImage"
            android:gravity="center|start"
            android:paddingStart="@dimen/spacing_small"
            android:textAllCaps="false"
            android:textSize="@dimen/size_16" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_small"
            android:id="@+id/linearPrice"
            android:paddingStart="@dimen/spacing_small"
            android:layout_toEndOf="@+id/cvProductImage"
            android:layout_below="@+id/tvCategoryName"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvProductPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="111"
                android:layout_gravity="center"
                android:textSize="@dimen/size_16" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/p_discount_layout"
                android:layout_marginStart="@dimen/margin_5"
                android:layout_marginLeft="3dp">
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvProductSpecialPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="123"
                android:textColor="@color/red"
                android:paddingEnd="@dimen/margin_4"

                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:textSize="@dimen/size_12"
                android:visibility="visible" />
            <View
                android:layout_width="0dp"
                android:layout_height="1dip"
                android:layout_margin="@dimen/margin_6"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:foregroundGravity="center"
                android:background="@color/red"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvNextAvailable"
            android:layout_width="@dimen/spacing_100"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/background_next_available"
            android:gravity="center"
            android:layout_below="@+id/linearPrice"
            android:layout_alignParentEnd="true"
            android:textSize="@dimen/size_10"
            android:paddingStart="@dimen/margin_2"
            android:paddingEnd="@dimen/margin_2"
            android:paddingTop="@dimen/margin_2"
            android:paddingBottom="@dimen/margin_2"
            android:text="Next Available at 06:00 am"
            android:textColor="@color/viewColor1"
            android:visibility="gone" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvDealExpire"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textColor="#811212"
            android:textSize="13sp"
            android:visibility="gone"
            android:layout_marginTop="5dp"
            tools:text="Expires: 22-Sep-2023"
            android:layout_marginStart="@dimen/margin_5"
            android:layout_marginEnd="@dimen/margin_5"
            android:layout_toEndOf="@+id/cvProductImage"
            android:layout_below="@+id/tv_spinner"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/tvDealExpire"
            android:layout_alignParentEnd="true"
            android:id="@+id/tv_linear"
            android:gravity="center">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvNoStock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:padding="@dimen/margin_4"
                android:text="out of Stock"
                android:textColor="@color/bg_cart"
                android:textSize="@dimen/size_18"
                android:visibility="gone" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvAddToCart"
                android:layout_width="100dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:background="@drawable/background_add_to_cart"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:padding="@dimen/margin_4"
                android:text="Add to cart"
                android:textColor="@color/purple_500"
                android:visibility="visible" />

            <LinearLayout
                android:id="@+id/linearProductQty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvReduceProduct"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/background_minus_button"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:text="-"
                    android:textColor="@color/textTitle"
                    android:textSize="@dimen/size_18" />

                <TextView
                    android:id="@+id/tvProductQty"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="@color/textHeader"
                    android:textSize="@dimen/size_18" />

                <TextView
                    android:id="@+id/tvAddProduct"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/background_add_button"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="@color/white"
                    android:textSize="@dimen/size_18" />


            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="@dimen/spacing_normal"
        android:layout_marginEnd="@dimen/spacing_normal"
        android:background="@color/viewColor"/>

</androidx.appcompat.widget.LinearLayoutCompat>



