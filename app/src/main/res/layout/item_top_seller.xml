<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:layout_marginLeft="5dp"
    android:background="#09BEC5C0"
    android:elevation="10dp"
    android:minHeight="@dimen/spacing_80">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:orientation="vertical"
        android:padding="2dp">

        <FrameLayout
            android:id="@+id/ts_frame"
            android:layout_width="70dp"
            android:layout_height="0dp"

            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent">


            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ts_img"
                android:layout_width="70dp"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:src="@drawable/img3"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ts_ofer_img"
                android:layout_width="@dimen/spacing_30"
                android:layout_height="@dimen/spacing_30"
                android:layout_weight="1"
                android:scaleType="fitXY"
                android:src="@drawable/ic_offer" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/ts_ofer_txt"
                android:layout_width="30dp"
                android:layout_height="@dimen/spacing_30"
                android:gravity="center"
                android:text=""
                android:textColor="@color/white"
                android:textSize="@dimen/size_10"

                android:textStyle="bold" />


        </FrameLayout>

        <LinearLayout
            android:layout_width="160dp"
            android:layout_height="match_parent"

            android:layout_marginLeft="5dp"
            android:orientation="vertical"
            app:layout_constraintLeft_toRightOf="@+id/ts_frame"
            app:layout_constraintTop_toTopOf="parent">


            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/ts_product_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nike Air Max 2090"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintLeft_toRightOf="@+id/img1"
                app:layout_constraintTop_toTopOf="parent" />
            <!--                                        <androidx.appcompat.widget.AppCompatRatingBar-->
            <!--                                            android:id="@+id/ts_ratingbar"-->
            <!--                                            android:layout_width="wrap_content"-->
            <!--                                            android:layout_height="@dimen/spacing_20dp"-->
            <!--                                            android:numStars="6"-->
            <!--                                            android:paddingTop="1dp"-->
            <!--                                            android:paddingEnd="15dp"-->
            <!--                                            android:paddingStart="3dp"-->
            <!--                                            android:rating="6"-->
            <!--                                            android:progressTint="#FFC107"-->
            <!--                                            style="?android:attr/ratingBarStyleSmall" />-->

            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/ts_spinner"

                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_5"
                android:layout_marginBottom="@dimen/margin_5" />

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="2dp">


                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/ts_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="₹150"
                    android:textColor="@color/green"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/seller_discount_layout"
                    android:layout_width="35dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="3dp"
                    android:layout_toRightOf="@+id/ts_price">

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/ts_discount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="₹180"

                        android:textColor="@color/red"
                        android:textSize="11sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dip"
                        android:layout_margin="@dimen/margin_4"
                        android:background="@color/red"
                        android:foregroundGravity="center"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

            </RelativeLayout>
        </LinearLayout>


        <!--                                    <com.google.android.material.card.MaterialCardView-->
        <!--                                        app:layout_constraintRight_toRightOf="parent"-->
        <!--                                        app:layout_constraintBottom_toBottomOf="parent"-->
        <!--                                        android:layout_width="@dimen/payu_dimen_75dp"-->
        <!--                                        android:layout_height="35dp"-->
        <!--                                        android:layout_marginEnd="@dimen/margin_5"-->
        <!--                                        android:layout_marginBottom="@dimen/margin_5"-->
        <!--                                        android:layout_gravity="center">-->


        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/add_btn"

            android:layout_width="60dp"
            android:layout_height="30dp"
            android:layout_margin="@dimen/margin_5"
            android:background="@drawable/background_add_to_cart"
            android:backgroundTint="@color/white"
            android:elevation="10dp"
            android:fontFamily="@font/helvetica_regular"
            android:gravity="center"
            android:text="Add"
            android:textColor="@color/red"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toRightOf="parent" />

        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/addLinearProductQty"
            android:layout_width="0dp"
            android:layout_height="35dp"

            android:padding="@dimen/margin_2"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvNoStock"
                android:layout_width="wrap_content"
                android:layout_height="25dp"
                android:layout_gravity="center"
                android:fontFamily="@font/roboto_medium"
                android:gravity="center"
                android:padding="@dimen/margin_4"
                android:text="@string/out_of_stock"
                android:textColor="@color/bg_cart"
                android:textSize="@dimen/size_18"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvItemReduceProduct"
                android:layout_width="@dimen/addCartsize"
                android:layout_height="@dimen/addCartsize"
                android:background="@drawable/background_minus_button"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:text="-"
                android:textColor="@color/textTitle"
                android:textSize="@dimen/size_18" />

            <TextView
                android:id="@+id/tvItemProductQty"
                android:layout_width="@dimen/addCartsize"
                android:layout_height="@dimen/addCartsize"
                android:gravity="center"
                android:text="0"
                android:textColor="@color/textHeader"
                android:textSize="@dimen/size_18" />

            <TextView
                android:id="@+id/tvItemAddProduct"
                android:layout_width="@dimen/addCartsize"
                android:layout_height="@dimen/addCartsize"
                android:background="@drawable/background_add_button"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:text="+"
                android:textColor="@color/white"
                android:textSize="@dimen/size_18" />


        </androidx.appcompat.widget.LinearLayoutCompat>


