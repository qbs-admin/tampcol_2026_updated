<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    android:padding="@dimen/size_10">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/spacing_normal">

            <RelativeLayout
                android:id="@+id/headerLayout"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="-20dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/im_Collpasing"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:layout_marginStart="32dp"
                    android:layout_marginTop="32dp"
                    android:layout_marginEnd="32dp"
                    android:layout_marginBottom="32dp"
                    android:foregroundGravity="center"
                    android:padding="18dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/logo" />

            </RelativeLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_10"
                android:layout_marginBottom="@dimen/margin_5"
                android:gravity="center|left"
                android:lineSpacingExtra="@dimen/margin_5"
                android:text="Let's Login to your \nAccount"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tvYourName"
                style="@style/TextInputLayoutStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_5"
                android:hint="@string/label_email_address">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmailId"
                    style="@style/EditText"
                    android:imeOptions="actionNext"
                    android:maxLines="1"
                    app:boxStrokeWidth="1dip"
                    app:boxStrokeWidthFocused="0dp"
                    tools:text="" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilFirstName"
                style="@style/TextInputLayoutStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_10"
                android:hint="@string/label_password"
                app:passwordToggleEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    style="@style/EditText"
                    android:imeOptions="actionDone"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    app:boxStrokeWidth="1dip"
                    app:boxStrokeWidthFocused="0dp"
                    tools:text="" />
            </com.google.android.material.textfield.TextInputLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/signup_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:fontFamily="@font/poppins_medium"
                    android:gravity="end"
                    android:padding="3dp"
                    android:text="SignUp"
                    android:textColor="@color/textTitle"
                    android:textSize="15sp" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tvForgot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:layout_gravity="start"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:fontFamily="@font/poppins_medium"
                    android:padding="3dp"
                    android:text="@string/label_forgot_password"
                    android:textAllCaps="false"
                    android:textColor="@color/textTitle"
                    android:textSize="15sp" />

            </RelativeLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/login_button"
                android:layout_width="@dimen/spacing_200"
                android:layout_height="?actionBarSize"
                android:layout_marginStart="25dp"
                android:layout_marginTop="@dimen/spacing_normal"
                android:layout_marginEnd="25dp"
                android:drawableEnd="@drawable/address_arrow"
                android:text="@string/label_login"
                android:textColor="@android:color/white"
                android:textSize="@dimen/size_16"
                app:cornerRadius="@dimen/spacing_medium"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

<!--            <androidx.constraintlayout.widget.ConstraintLayout-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:layout_marginTop="@dimen/spacing_20dp">-->

<!--                <androidx.constraintlayout.widget.ConstraintLayout-->
<!--                    android:id="@+id/login_withotp"-->
<!--                    android:layout_width="wrap_content"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:layout_marginStart="@dimen/spacing_10"-->
<!--                    app:layout_constraintEnd_toEndOf="parent"-->
<!--                    app:layout_constraintStart_toStartOf="parent"-->
<!--                    app:layout_constraintTop_toTopOf="parent">-->


                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/login_withotp"
                        android:layout_marginTop="20dp"
                        android:layout_width="170dp"
                        android:layout_height="?actionBarSize"
                        android:shadowColor="#FFFFFF"
                        android:shadowDx="0"
                        style="@style/CustomButtonStyle"
                        android:shadowDy="0"
                        android:shadowRadius="2"
                        android:text="LOGIN WITH OTP"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!--                    <androidx.appcompat.widget.AppCompatTextView-->
                    <!--                        android:id="@+id/log"-->
                    <!--                        android:layout_width="wrap_content"-->
                    <!--                        android:layout_height="wrap_content"-->
                    <!--                        android:layout_marginTop="@dimen/spacing_small"-->
                    <!--                        android:fontFamily="@font/roboto_medium"-->
                    <!--                        android:gravity="end"-->
                    <!--                        android:padding="3dp"-->
                    <!--                        android:text="Login With otp"-->
                    <!--                        android:textSize="16sp"-->
                    <!--                        app:layout_constraintStart_toStartOf="parent"-->
                    <!--                        app:layout_constraintTop_toTopOf="parent" />-->

                    <!--                    <androidx.appcompat.widget.AppCompatImageView-->
                    <!--                        android:layout_width="wrap_content"-->
                    <!--                        android:layout_height="wrap_content"-->
                    <!--                        android:layout_marginStart="@dimen/margin_5"-->
                    <!--                        android:src="@drawable/arrow_img"-->


                    <!--                        app:layout_constraintBottom_toBottomOf="parent"-->
                    <!--                        app:layout_constraintLeft_toRightOf="@+id/log" />-->


<!--                </androidx.constraintlayout.widget.ConstraintLayout>-->
<!--            </androidx.constraintlayout.widget.ConstraintLayout>-->

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/skip_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="@dimen/spacing_20dp"
                android:layout_marginBottom="@dimen/spacing_20dp"
                android:fontFamily="@font/roboto_medium"
                android:paddingTop="@dimen/margin_5"
                android:text="@string/label_skip"
                android:textAllCaps="false"
                android:textSize="@dimen/size_16"
                app:cornerRadius="@dimen/spacing_medium" />

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/signup_btn">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivGoogleLogin"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_google" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/ivFacebookLogin"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="12dp"
                    android:visibility="gone"
                    android:layout_toEndOf="@+id/ivGoogleLogin"
                    android:src="@drawable/ic_facebook" />
            </RelativeLayout>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </ScrollView>

    <ProgressBar
        android:id="@+id/pbUserLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|center_horizontal"
        android:visibility="gone" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>