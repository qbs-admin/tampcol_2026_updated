<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/couponCode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MAX3000"
        android:textColor="@color/black"
        android:textSize="@dimen/size_18"
        android:layout_marginLeft="@dimen/spacing_10"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/coupon_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MAX3000"
        android:visibility="gone"
        android:textSize="@dimen/size_14"
        android:layout_marginStart="@dimen/spacing_20dp"
        android:layout_marginLeft="@dimen/spacing_20dp"
        android:layout_marginTop="@dimen/margin_5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/couponCode"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/valid_date_lable"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Valid Till -"
        android:textColor="@color/black"
        android:textSize="@dimen/size_14"
        android:layout_marginStart="@dimen/spacing_20dp"
        android:layout_marginLeft="@dimen/spacing_20dp"
        android:layout_marginTop="@dimen/margin_5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/coupon_text"/>


    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/valid_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="15-04-97"
        app:layout_constraintLeft_toRightOf="@+id/valid_date_lable"
        android:textColor="@color/black"
        android:textSize="@dimen/size_14"
        android:layout_marginStart="@dimen/spacing_20dp"
        android:layout_marginLeft="@dimen/spacing_20dp"
        android:layout_marginTop="@dimen/margin_5"
        app:layout_constraintBaseline_toBaselineOf="@+id/valid_date_lable"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        app:layout_constraintTop_toBottomOf="@+id/valid_date"
        android:layout_margin="@dimen/spacing_10"
        android:background="@color/cool_grey"
        />
</androidx.constraintlayout.widget.ConstraintLayout>