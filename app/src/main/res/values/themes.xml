<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.LaaFresh" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
<!--        <item name="colorSecondary">@color/teal_200</item>-->
<!--        <item name="colorSecondaryVariant">@color/teal_700</item>-->
<!--        <item name="colorOnSecondary">@color/black</item>-->
        <!-- Status bar color. -->
      <!--  <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>-->
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:fitsSystemWindows">false</item>



        <!-- Customize your theme here. -->

        <item name="buttonStyle">@style/CustomButtonStyle</item>
    </style>

    <style name="Theme.LaaFresh.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
<!--        <item name="android:windowLightStatusBar">true</item>-->
        <item name="android:statusBarColor">@color/purple_500</item>
    </style>

    <style name="Theme.LaaFresh.NoStatusbar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowTranslucentStatus">false</item>
    </style>

    <style name="Theme.LaaFresh.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.LaaFresh.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="ToolBarTitle" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@android:color/black</item>
    </style>

    <style name="ThemeNavigation">
        <item name="colorPrimary">@color/purple_700</item>
        <item name="colorSurface">@color/purple_500</item>
        <item name="colorOnSurface">@color/color_on_surface</item>
        <item name="fontFamily">@font/roboto_regular</item>
        <item name="android:textSize">@dimen/font_small</item>
    </style>

    <style name="EditText">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_width">match_parent</item>
    </style>
<!--    <item name="android:digits">abcdefghijklmnopqrstuvwxyz ABCDEFGHIJKLMNOPQRSTUVWXYZ 1234567890 @ . /</item>-->
<!--    <item name="android:inputType">text</item>-->


    <style name="TextInputLayoutStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
<!--        <item name="boxStrokeWidth">2dp</item>-->
<!--        <item name="colorOnBackground">#fff</item>-->
<!--        <item name="android:foregroundTint">#fff</item>-->
<!--        <item name="android:fillColor">#fff</item>-->
        <item name="color">#fff</item>
        <item name="hintTextAppearance">@style/TextAppearance.TextInputLayout.HintText</item>
        <item name="hintTextColor">@color/cool_grey</item>
        <item name="android:paddingBottom">8dp</item>

        <item name="colorControlActivated">@color/purple_700</item>
        <item name="colorControlHighlight">@color/purple_700</item>

        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>

    </style>
    <style name="Toolbar" parent="ThemeOverlay.AppCompat.Dark.ActionBar">
        <item name="android:textSize">30sp</item>
    </style>

    <style name="EditTextTheme" parent="Theme.AppCompat.Light.DarkActionBar">
    <item name="colorControlNormal">@color/viewColor</item>
    <item name="colorControlActivated">@color/purple_700</item>
    <item name="colorControlHighlight">@color/purple_700</item>
    <item name="android:textSize">@dimen/size_18</item>
    </style>


<!--    <style name="Widget.TextInputLayout" parent="Widget.Design.TextInputLayout">-->
<!--        <item name="hintTextAppearance">@style/TextAppearance.TextInputLayout.HintText</item>-->
<!--        <item name="hintTextColor">@color/cool_grey</item>-->
<!--        <item name="android:paddingBottom">8dp</item>-->
<!--    </style>-->

    <style name="Widget.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="hintTextAppearance">@style/TextAppearance.TextInputLayout.HintText</item>
        <item name="hintTextColor">@color/cool_grey</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="boxStrokeWidth">2dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
    </style>

    <style name="TextAppearance.TextInputLayout.HintText" parent="TextAppearance.MaterialComponents.Subtitle2">
        <item name="android:textColor">?android:attr/textColorPrimary</item>

    </style>


    <style name="EditTextThemeOverlay" parent="ThemeOverlay.AppCompat">
<!--        <item name="colorAccent">@android:color/holo_blue_light</item>-->
    </style>

    <style name="CustomButtonStyle">
        <item name="android:background">@drawable/buttonshape</item> <!-- Custom background drawable -->
        <item name="android:textColor">#FFFFFF</item> <!-- Text color -->
        <item name="android:textSize">15sp</item> <!-- Text size -->
        <!-- Other properties as needed -->
    </style>
</resources>